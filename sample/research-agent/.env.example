# Copy this to .env and set one credential method.
# The CLI/runtime auto-loads .env from the current working directory.
# Priority: Ollama/custom endpoint > ANTHROPIC_API_KEY > CLAUDE_CODE_OAUTH_TOKEN

# --- Ollama / Custom endpoint (highest priority) ---
# See: https://docs.ollama.com/integrations/claude-code#manual-setup
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_AUTH_TOKEN=ollama
# ANTHROPIC_API_KEY=""

# --- Anthropic API ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OAuth (personal dev use) ---
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here
